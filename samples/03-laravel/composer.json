{
  "name": "bella-sample/laravel",
  "description": "Bella Baxter: Laravel sample using bella-baxter/laravel package",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "bella-baxter/laravel": "*"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../packages/laravel"
    },
    {
      "type": "path",
      "url": "../.."
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
