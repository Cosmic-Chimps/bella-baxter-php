{
  "name": "bella-baxter/sdk",
  "description": "Official PHP SDK for the Bella Baxter secret management platform",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "secrets",
    "vault",
    "bella-baxter",
    "secret-management"
  ],
  "homepage": "https://bella-baxter.io",
  "support": {
    "source": "https://github.com/cosmic-chimps/bella-baxter-php",
    "issues": "https://github.com/cosmic-chimps/bella-baxter-php/issues",
    "docs": "https://docs.bella-baxter.io"
  },
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "ext-openssl": "*",
    "microsoft/kiota-abstractions": "^1.0",
    "microsoft/kiota-http-guzzle": "^1.0",
    "microsoft/kiota-serialization-json": "^1.0",
    "microsoft/kiota-serialization-text": "^1.0",
    "microsoft/kiota-serialization-form": "^1.0",
    "microsoft/kiota-serialization-multipart": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "BellaBaxter\\": "src/",
      "BellaBaxter\\Generated\\": "src/generated/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BellaBaxter\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable"
}
